rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Imagens de anúncios: leitura pública, upload limitado a 5MB e apenas imagens
    match /anuncios/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
